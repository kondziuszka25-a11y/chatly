datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ONLINE
  OFFLINE
}

enum NotificationType {
  NEW_MESSAGE
  GROUP_INVITE
  MENTION
}

model User {
  id                   Int                  @id @default(autoincrement())
  email                String               @unique
  username             String               @unique
  passwordHash         String
  avatarUrl            String?              // Nullable for default placeholders
  status               UserStatus           @default(OFFLINE)
  lastActive           DateTime             @default(now())
  resetPasswordToken   String?              @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  // Relationships
  memberships          ConversationMember[]
  sentMessages         Message[]
  messageReactions     MessageReaction[]
  notifications        Notification[]       @relation("ReceivedNotifications")
  sentNotifications    Notification[]       @relation("SentNotifications")
  
  // Blocking System
  blockedUsers         BlockedUser[]        @relation("BlockerRelation")
  blockedBy            BlockedUser[]        @relation("BlockedRelation")

  // Group ownership
  ownedConversations   Conversation[]       @relation("GroupOwner")
}

model Conversation {
  id            Int                  @id @default(autoincrement())
  name          String?              // Nullable for 1:1 conversations
  avatarUrl     String?              // Group avatar
  isGroup       Boolean              @default(false)
  ownerId       Int?                 // Owner of the group chat
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  // Relationships
  owner         User?                @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members       ConversationMember[]
  messages      Message[]
  notifications Notification[]
}

model ConversationMember {
  id             Int          @id @default(autoincrement())
  userId         Int
  conversationId Int
  isPinned       Boolean      @default(false)
  lastReadAt     DateTime     @default(now())
  joinedAt       DateTime     @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model Message {
  id             Int               @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String            @db.Text
  fileUrl        String?           // For image/file attachment
  fileType       String?           // e.g. "image/jpeg", "image/png"
  isEdited       Boolean           @default(false)
  isDeleted      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions      MessageReaction[]
}

model MessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  emoji     String   // e.g., "👍", "❤️", "😂"
  createdAt DateTime @default(now())

  // Relations
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId]) // Limit to one reaction per user per message
}

model BlockedUser {
  id        Int      @id @default(autoincrement())
  blockerId Int
  blockedId Int
  createdAt DateTime @default(now())

  // Relations
  blocker   User     @relation("BlockerRelation", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedRelation", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Notification {
  id             Int              @id @default(autoincrement())
  userId         Int              // Receiver of notification
  senderId       Int?             // User trigger (e.g. sender of invite)
  conversationId Int?             // Associated chat
  type           NotificationType
  content        String
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  // Relations
  user           User             @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)
  sender         User?            @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}
